{
  "expo": {
    "name": "ReUse",
    "slug": "ReUse",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reuse",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
      "expo-image-picker",
        {
          "cameraPermission": "O ReUse! precisa de acesso à câmera para cadastrar itens."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}